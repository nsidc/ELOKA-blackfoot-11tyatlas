                    <a href="{{ item.url }}">{{ item.data.title }}</a>
                </li>
            {%- endfor -%}
        </ul>
    </div>
    <div class="flex items-end">
        <a class="btn btn-ghost text-xl">Blackfoot Atlas</a>
