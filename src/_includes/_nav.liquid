            <ul class="menu menu-horizontal p-0">
            {%- for item in collections.nav -%}
                        <li>
                            <a href="{{ item.url }}">{{ item.data.title }}</a>
                        </li>
                    {%- endfor -%}
            </ul>
        </div>
    </div>
</div>