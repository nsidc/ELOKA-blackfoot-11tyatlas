{% include "./node_modules/ol/ol.css" %}
{% include "./node_modules/ol-layerswitcher/dist/ol-layerswitcher.css" %}

@media (prefers-color-scheme: light) {
  #legend-container {
      background-color: #334444;
      color: #FFFFFF;
  }

  .map .layer-switcher .panel {
    background-color: #334444;
    color: #FFFFFF;
  }
}

@media (prefers-color-scheme: dark) {
  #legend-container {
      background-color: color-mix(in oklab, var(--color-base-100), transparent 10%);
  }

  .map .layer-switcher .panel {
    background-color: color-mix(in oklab, var(--color-base-100), transparent 3%);
  }
}



.map .layer-switcher {
    left: 0.5em;
    right: unset;
    top: 80px;
    @media (width >= 40rem) { 
      top: 65px;
    }
}

.layer-switcher.shown.layer-switcher-activation-mode-click {
  padding-right: 34px;
}

.layer-switcher.shown.layer-switcher-activation-mode-click > button {
  right: 0;
  border-left: 0;
}

#featureCard .card {
  background: 
  color-mix(in oklab, var(--color-base-100), transparent 10%);
}